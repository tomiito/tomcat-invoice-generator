# Database (local: Docker Compose Postgres on port 5433)
POSTGRES_URL=postgresql://invoice_user:invoice_pass@localhost:5433/invoice_db

# Auth0 - Get these from your Auth0 dashboard (Applications > Your App > Settings)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id-here
VITE_AUTH0_AUDIENCE=
